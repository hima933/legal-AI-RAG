# Backend Configuration Template
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGO_DB_NAME=legal_ai

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
ENVIRONMENT=development

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000
ALLOW_CREDENTIALS=true
ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOW_HEADERS=Content-Type,Authorization

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Security
DEBUG_MODE=false
# LLM Configuration
# Choose provider: ollama, grok, openai, huggingface
LLM_PROVIDER=ollama

# Ollama Configuration (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Grok Configuration (cloud API - free tier available)
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=mixtral-8x7b-32768

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# HuggingFace Configuration
HUGGINGFACE_API_TOKEN=your_huggingface_token_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Fallback Providers (comma-separated)
ENABLE_FALLBACK=true
FALLBACK_PROVIDERS=grok,openai